# PostgreSQL connection string
DATABASE_URL=postgresql://savemyass:savemyass@localhost:5432/savemyass

# Clerk (user auth + Google OAuth)
CLERK_SECRET_KEY=sk_test_...

# Anthropic (NL translation + classification)
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for MCP server → API server authentication
MCP_SERVICE_SECRET=change-me-to-a-secure-random-string

# Server ports
API_PORT=3000
MCP_PORT=3001

# Environment
NODE_ENV=development

# Auto-approve HIL requests in development (set to true for testing)
APPROVAL_AUTO_APPROVE=false
